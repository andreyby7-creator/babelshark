# Meteor (modules-runtime) ожидает «плоский» node_modules для npm-пакетов (`@babel/runtime` и др.).
# Дефолтный isolated layout pnpm даёт Cannot find module … при `meteor run`.
node-linker=hoisted

# Локально: меньше шума от progress. В CI переопределение: PNPM_CONFIG_REPORTER=silent.
reporter=append-only
