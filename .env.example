# Скопировать в `.env` при необходимости или задать переменные в shell / CI.
# Совпадает с дефолтами в `imports/api/mysql.ts` и `server/typeorm.ts` (см. `docker-compose.yml`).
#
# Meteor сам по себе не подгружает файл `.env`; для локали: `export $(grep -v '^#' .env | xargs)` или оболочка/IDE.

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASS=root
DB_NAME=babel
